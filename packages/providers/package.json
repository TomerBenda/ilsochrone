{
  "name": "@ilsochrone/providers",
  "version": "0.0.1",
  "private": true,
  "description": "Provider abstraction for isochrones, POIs, basemap tiles, and (phase-2) transit data.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./isochrone": "./src/isochrone/index.ts",
    "./poi": "./src/poi/index.ts",
    "./tile": "./src/tile/index.ts",
    "./transit": "./src/transit/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ilsochrone/engine": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@turf/area": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@turf/intersect": "^7.1.0",
    "@turf/union": "^7.1.0",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^20.16.10",
    "eslint": "^9.12.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  }
}
