    "@turf/difference": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@types/d3-contour": "^3.0.6",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^20.16.10",
    "eslint": "^9.12.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vitest": "^2.1.2"
  }
